{
  "rules": {
    "users": {
      ".indexOn": ["usernameLower", "inviteCode"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid",
        "wallet": {
          ".write": false,
          "balance": { ".validate": "newData.isNumber() && newData.val() >= 0" }
        },
        "isPremium": { ".write": false },
        "isLifetime": { ".write": false },
        "entitlementUpdatedAt": { ".write": false },
        "processedTransactions": { ".write": false }
      }
    },

    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "friendships": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null"
      }
    },

    "friendRequests": {
      ".read": "auth != null",
      "$rid": {
        ".write": "auth != null && (!data.exists() || data.child('toUserId').val() == auth.uid || data.child('fromUserId').val() == auth.uid)",
        "fromUserId":  { ".validate": "newData.val() == auth.uid || data.exists()" }
      }
    },

    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('hostId').val() == auth.uid)",
        "players": {
          "$pid": {
            ".write": "auth != null && (auth.uid == $pid || data.parent().parent().child('hostId').val() == auth.uid)"
          }
        },
        "status": { ".validate": "newData.isString()" }
      }
    },

    "sessions": {
      "$sid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "aiUsage": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": false
      }
    },

    "telemetry": {
      ".read": false,
      "$eid": {
        ".write": "auth != null && newData.child('userId').val() == auth.uid"
      }
    }
  }
}
